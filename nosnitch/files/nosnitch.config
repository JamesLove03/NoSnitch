config nosnitch 'main'
	option enabled              '1'

	# Patch 2: L3 gateway-bouncing mitigation
	option l3_isolation         '1'

	# Patch 3: port-stealing / MAC-to-port locking
	option mac_lock             '1'
	option mac_lock_bridge      '1'
	option mac_lock_network     '0'
	option roaming_grace_ms     '500'

	# Patch 1 Step 6: broadcast anomaly detection
	option broadcast_anomaly    '1'
	option broadcast_rate_limit '20'
	option broadcast_block_time '60'

	# Patch 3 Step 7: cross-AP sync (opt-in, wired backhaul only)
	option sync_interface       'eth0'
	option sync_group           '239.192.77.65'
	option sync_port            '4719'
	option heartbeat_interval   '5'
	option heartbeat_timeout    '20'

	option bridge               'br-lan'
	# option gateway_mac        'aa:bb:cc:dd:ee:ff'

	# Wireless ifaces managed by hostapd. Required for the ebtables
	# MAC-to-port locking (Patch 3 Steps 2/3) and the ip -6 monitor
	# watcher (Patch 2 Step 5). Assoc events auto-add any iface not
	# listed here, but pre-seeding lets init-time rules apply.
	list wlan_iface             'phy0-ap0'
	list wlan_iface             'phy1-ap0'
